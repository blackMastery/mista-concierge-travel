# Supabase — copy to .env.local and fill with your project's values
# Project Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY, never expose to the browser. Required by the
# admin team-management page to create logins and list/manage admins.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Bootstrap super admins — comma-separated emails treated as full-access super
# admins until a matching admin_users row exists (so the first owner can reach
# /admin/access and promote themselves).
ADMIN_ALLOWED_EMAILS=owner@example.com

# Site URL (used in booking emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend — booking confirmation emails (optional; skipped if unset)
RESEND_API_KEY=re_xxxxxxxx
BOOKING_FROM_EMAIL=Mista Travel <bookings@yourdomain.com>
BOOKING_ADMIN_EMAIL=hello@mistatravel.com
